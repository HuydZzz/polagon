# Polagon frontend configuration. Copy to `.env.local` and fill once contracts are deployed.

# Portaldot RPC endpoint — confirm via https://portaldot-dev.readthedocs.io/en/latest/
NEXT_PUBLIC_RPC_URL=wss://rpc.testnet.portaldot.io

# Deployed contract addresses (auto-populated by `make deploy`)
NEXT_PUBLIC_FACTORY_ADDRESS=
NEXT_PUBLIC_REPUTATION_ADDRESS=
NEXT_PUBLIC_POLLS_ADDRESS=

# Display config
NEXT_PUBLIC_CHAIN_NAME=Portaldot Testnet
NEXT_PUBLIC_NATIVE_SYMBOL=POT
NEXT_PUBLIC_NATIVE_DECIMALS=12
